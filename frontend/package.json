{
  "name": "@bdanielmr/ruta-casino-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-lib/index.cjs",
  "module": "dist-lib/index.js",
  "types": "dist-lib/lib-index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-lib/lib-index.d.ts",
      "import": "./dist-lib/index.js",
      "require": "./dist-lib/index.cjs"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist-lib",
    "styles.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --mode lib && tsc -p tsconfig.lib.json && cp src/styles.css styles.css",
    "pack:local": "npm run build:lib && npm pack",
    "preview": "vite preview"
  },
  "dependencies": {
    "pixi.js": "^8.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^5.4.12"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
